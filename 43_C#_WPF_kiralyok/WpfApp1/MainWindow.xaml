<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TabControl HorizontalAlignment="Left" Height="404" Margin="0,5,0,0" VerticalAlignment="Top" Width="782">
            <TabItem Header="Uralkodó">
                <Grid Background="#FFE5E5E5">
                    <ComboBox Name="cbx_ural" HorizontalAlignment="Left" Height="30" Margin="37,60,0,0" VerticalAlignment="Top" Width="167" SelectionChanged="Cbx_ural_SelectionChanged"/>
                    
                    <Label Name="lb_szul" Content="" HorizontalAlignment="Left" Height="62" Margin="173,106,0,0" VerticalAlignment="Top" Width="182"/>
                    <Label Content="Született:" HorizontalAlignment="Left" Height="62" Margin="109,106,0,0" VerticalAlignment="Top" Width="59"/>
                    <Label Content="Meghalt:" HorizontalAlignment="Left" Height="62" Margin="109,173,0,0" VerticalAlignment="Top" Width="59"/>
                    <Label x:Name="lb_hal" Content="" HorizontalAlignment="Left" Height="62" Margin="173,173,0,0" VerticalAlignment="Top" Width="182"/>
                    <Label Content="Név:" HorizontalAlignment="Left" Height="62" Margin="109,235,0,0" VerticalAlignment="Top" Width="59"/>
                    <Label x:Name="lb_ragnev" Content="" HorizontalAlignment="Left" Height="62" Margin="173,240,0,0" VerticalAlignment="Top" Width="182"/>

                </Grid>
            </TabItem>
            <TabItem Header="Keresés név alapján">
                <Grid Background="#FFE5E5E5">
                    <TextBox Name="tbx_nev" HorizontalAlignment="Left" Height="27" Margin="41,27,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="151"/>
                    <Button Name="btn_nevKeres" Content="Keresés" HorizontalAlignment="Left" Height="27" Margin="218,27,0,0" VerticalAlignment="Top" Width="117" Click="Btn_nevKeres_Click"/>
                    <ListBox Name="lbx_nevLista" HorizontalAlignment="Left" Height="245" Margin="41,98,0,0" VerticalAlignment="Top" Width="294"/>
                </Grid>
            </TabItem>
            <TabItem Header="Uralkodó ház felvitele">
                <Grid Background="#FFE5E5E5">
                    <TextBox HorizontalAlignment="Left" Height="32" Margin="31,48,0,0" TextWrapping="Wrap" Name="tbx_haznev" Text="" VerticalAlignment="Top" Width="202" RenderTransformOrigin="0.5,0.5">
                        <TextBox.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform Angle="2.527"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </TextBox.RenderTransform>
                    </TextBox>
                    <Button Content="Button" HorizontalAlignment="Left" Height="76" Margin="60,136,0,0" VerticalAlignment="Top" Width="242" Click="Button_Click"/>

                </Grid>
            </TabItem>
            <TabItem Header="Uralkodó felvitel" HorizontalAlignment="Left" Height="20" VerticalAlignment="Top" Width="54">
                <Grid Background="#FFE5E5E5">
                    <TextBox Name="tbx_urnev" HorizontalAlignment="Left" Height="27" Margin="10,24,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="162"/>
                    <TextBox Name="tbx_ragnev" HorizontalAlignment="Left" Height="22" Margin="10,66,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="162"/>
                    <TextBox Name="tbx_szul" HorizontalAlignment="Left" Height="26" Margin="10,106,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="162"/>
                    <TextBox Name="tbx_hal" HorizontalAlignment="Left" Height="27" Margin="10,145,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="162"/>
                    <ComboBox Name="cbx_uralhaz" HorizontalAlignment="Left" Height="37" Margin="10,187,0,0" VerticalAlignment="Top" Width="162"/>
                    <Button Content="Felvitel" HorizontalAlignment="Left" Height="36" Margin="218,168,0,0" VerticalAlignment="Top" Width="108" Click="Button_Click_1"/>
                </Grid>
            </TabItem>
            <TabItem Header="Keresés ház" HorizontalAlignment="Left" Height="20" VerticalAlignment="Top" Width="54">
                <Grid Background="#FFE5E5E5">
                    <TextBox x:Name="tbx_haz" HorizontalAlignment="Left" Height="23" Margin="58,75,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
                    <Button  Content="Keresés" HorizontalAlignment="Left" Margin="228,75,0,0" VerticalAlignment="Top" Width="75" Click="Button_Click_2"/>
                    <ListBox x:Name="lbx_hazkeres" HorizontalAlignment="Left" Height="166" Margin="58,183,0,0" VerticalAlignment="Top" Width="307"/>
                    <Label Content="Add meg az uralkodó ház nevét" HorizontalAlignment="Left" Margin="58,33,0,0" VerticalAlignment="Top"/>
                </Grid>
            </TabItem>
            <TabItem Header="Keresés-mikor" HorizontalAlignment="Left" Height="20" VerticalAlignment="Top" Width="129" Margin="-2,-2,-73,0">
                <Grid Background="#FFE5E5E5">
                    <ComboBox Name="cbx_metmed" HorizontalAlignment="Left" Margin="79,49,0,0" VerticalAlignment="Top" Width="120" SelectionChanged="Cbx_metmed_SelectionChanged"/>
                    <Label Name="lb_haznev" Content="Label" HorizontalAlignment="Left" Margin="83,93,0,0" VerticalAlignment="Top"/>
                    <Label Name="lb_urnev" Content="Label" HorizontalAlignment="Left" Margin="83,137,0,0" VerticalAlignment="Top"/>
                </Grid>
            </TabItem>
            <TabItem Header="Felvitel hivatal" HorizontalAlignment="Left" Height="20" VerticalAlignment="Top" Width="129" Margin="-2,-2,0,0">
                <Grid Background="#FFE5E5E5">
                    <ComboBox x:Name="cbx_uralkodolenyil" HorizontalAlignment="Left" Margin="79,49,0,0" VerticalAlignment="Top" Width="120" SelectionChanged="Cbx_uralkodolenyil_SelectionChanged"/>
                    <TextBox x:Name="tbx_mettolFelvitel" HorizontalAlignment="Left" Height="23" Margin="79,89,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
                    <TextBox x:Name="tbx_meddigFelvitel" HorizontalAlignment="Left" Height="23" Margin="79,117,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
                    <TextBox x:Name="tbx_koronazasiev" HorizontalAlignment="Left" Height="23" Margin="79,145,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
                    <Button Content="Felvitel" HorizontalAlignment="Left" Margin="79,173,0,0" VerticalAlignment="Top" Width="120" Height="31" Click="Button_Click_3"/>
                </Grid>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
