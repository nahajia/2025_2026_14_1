<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TabControl HorizontalAlignment="Left" Height="409" Margin="-5,10,0,0" VerticalAlignment="Top" Width="787">
            <TabItem Header="Telefonok">
                <Grid Background="#FFE5E5E5" Margin="0,8,-10,2">
                    <ComboBox Name="cbx_telefon" HorizontalAlignment="Left" Height="24" Margin="7,4,0,0" VerticalAlignment="Top" Width="771" RenderTransformOrigin="0.5,0.5" SelectionChanged="Cbx_telefon_SelectionChanged">
                        <ComboBox.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform Angle="-0.11"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </ComboBox.RenderTransform>
                    </ComboBox>
                    <TextBlock HorizontalAlignment="Left" Height="26" Margin="18,42,0,0" TextWrapping="Wrap" Text="Márka" VerticalAlignment="Top" Width="82"/>
                    <TextBox Name="tbx_marka" Background="#FF00E8FF" HorizontalAlignment="Left" Height="23" Margin="119,41,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="662"/>
                    <TextBlock HorizontalAlignment="Left" Height="26" Margin="18,82,0,0" TextWrapping="Wrap" Text="Modell" VerticalAlignment="Top" Width="82"/>
                    <TextBox Name="tbx_modell" Background="#FF00E8FF" HorizontalAlignment="Left" Height="23" Margin="119,82,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="662"/>
                    <TextBlock HorizontalAlignment="Left" Height="26" Margin="18,130,0,0" TextWrapping="Wrap" Text="Ár" VerticalAlignment="Top" Width="82"/>
                    <TextBlock HorizontalAlignment="Left" Height="26" Margin="148,130,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="82"><Run Text="Új"/><Run Text=":"/></TextBlock>
                    <TextBlock HorizontalAlignment="Left" Height="26" Margin="148,177,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="82"><Run Text="Használt:"/><LineBreak/><Run/></TextBlock>
                    <TextBox Name="tbx_ujar" Background="#FF00E8FF" HorizontalAlignment="Left" Height="23" Margin="198,130,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="583"/>
                    <TextBox Name="tbx_hasznaltar" Background="#FF00E8FF" HorizontalAlignment="Left" Height="23" Margin="198,177,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="583"/>
                    <TextBlock HorizontalAlignment="Left" Height="26" Margin="18,226,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="82"><Run Text="Telefon típusa"/><LineBreak/><Run/></TextBlock>
                    <TextBox Name="tbx_tipus" Background="#FF00E8FF" HorizontalAlignment="Left" Height="23" Margin="119,226,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="662"/>
                    <TextBlock HorizontalAlignment="Left" Height="26" Margin="18,287,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="82"><Run Text="Kijelző mérete"/><LineBreak/><Run/></TextBlock>
                    <TextBox Name="tbx_kijelzo" Background="#FF00E8FF" HorizontalAlignment="Left" Height="23" Margin="119,287,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="662"/>
                    <TextBlock HorizontalAlignment="Left" Height="26" Margin="18,340,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="82"><Run Text="Telefon leírása"/><LineBreak/><Run/></TextBlock>
                    <TextBox Name="tbx_leiras" Background="#FF00E8FF" HorizontalAlignment="Left" Height="41" Margin="119,325,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="662"/>
                </Grid>
            </TabItem>
            <TabItem Header="Kereső ár alapján">
                <Grid Background="#FFE5E5E5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32*"/>
                        <ColumnDefinition Width="749*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Minimum (új) ár:" HorizontalAlignment="Left" Height="25" Margin="10,10,0,0" VerticalAlignment="Top" Width="100" Grid.ColumnSpan="2"/>
                    <TextBox Name="tbx_minimum" HorizontalAlignment="Left" Height="25" Margin="83,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="319" Grid.Column="1"/>
                    <Label Content="Maximum (új) ár:" HorizontalAlignment="Left" Height="25" Margin="407,10,0,0" VerticalAlignment="Top" Width="100" Grid.Column="1"/>
                    <TextBox Name="tbx_maximum" HorizontalAlignment="Left" Height="25" Margin="507,10,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="207" Grid.Column="1"/>
                    <Button Content="Button" HorizontalAlignment="Left" Height="19" Margin="10,40,0,0" VerticalAlignment="Top" Width="736" Grid.ColumnSpan="2" Click="Button_Click"/>
                    <ListBox Name="lbx_kimenet" Grid.ColumnSpan="2" HorizontalAlignment="Left" Height="255" Margin="10,116,0,0" VerticalAlignment="Top" Width="761"/>
                </Grid>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
